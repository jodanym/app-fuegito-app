              { "emoji": "🍊", "valor": "naranja", "texto": "Naranja" },
              { "emoji": "📕", "valor": "libro", "texto": "Libro" },
              { "emoji": "🪙", "valor": "moneda", "texto": "Moneda" }
            ],
            "correcta": "libro",
            "pista": "Piensa en la forma, no en para qué sirve."
          }
        }
      ]
