{
  "id": "brasas-critica-u1-l1",
  "version": 2,
  "paquete": "brasas",
  "habilidad": "critica",
  "objetivo": "Detectar lo que no encaja en una escena",
  "lectura": { "dosis": "frase", "texto": "Observo bien antes de decidir." },
  "personaje": "desconocido",
  "recompensa": "medalla_lupa",
  "modos": {
    "interactivo": {
      "gancho": "Cambié algo a escondidas en cada lugar. Usa tus ojos de detective: ¿qué está fuera de lugar?",
      "retos": [
        {
          "tipo": "cual_no_encaja",
          "enunciado": "En la playa con mucho sol, ¿qué NO encaja?",
          "datos": {
            "opciones": [
              { "emoji": "🏖️", "valor": "arena", "texto": "Arena" },
              { "emoji": "🌊", "valor": "olas", "texto": "Olas" },
              { "emoji": "⛄", "valor": "muneco_de_nieve", "texto": "Muñeco de nieve" }
            ],
            "correcta": "muneco_de_nieve",
            "pista": "Con tanto calor, ¿qué se derretiría?"
          }
        },
        {
          "tipo": "cual_no_encaja",
          "enunciado": "En la cocina, ¿qué NO debería estar?",
          "datos": {
            "opciones": [
              { "emoji": "🍳", "valor": "sarten", "texto": "Sartén" },
              { "emoji": "🥄", "valor": "cuchara", "texto": "Cuchara" },
              { "emoji": "🚲", "valor": "bicicleta", "texto": "Bicicleta" }
            ],
            "correcta": "bicicleta",
            "pista": "¿Con qué cocinas y comes?"
          }
        },
        {
          "tipo": "cual_no_encaja",
          "enunciado": "En una noche con estrellas, ¿qué está raro?",
          "datos": {
            "opciones": [
              { "emoji": "🌙", "valor": "luna", "texto": "Luna" },
              { "emoji": "🦉", "valor": "buho", "texto": "Búho" },
              { "emoji": "☀️", "valor": "sol", "texto": "Sol brillando" }
            ],
            "correcta": "sol",
            "pista": "De noche el sol no brilla."
          }
        }
      ]
    }
  }
}
