{
  "id": "brasas-logica-u1-l1",
  "version": 2,
  "paquete": "brasas",
  "habilidad": "logica",
  "objetivo": "Descubrir patrones que se repiten",
  "lectura": { "dosis": "frase", "texto": "Miro el patrón y descubro la regla." },
  "personaje": "desconocido",
  "recompensa": "medalla_patron",
  "modos": {
    "interactivo": {
      "gancho": "Soy Desconocido. Cada patrón esconde una regla secreta. Descúbrela y dime qué sigue.",
      "retos": [
        {
          "tipo": "patron_visual",
          "enunciado": "Patrón ABAB: ¿qué figura sigue?",
          "datos": {
            "secuencia": ["🔺", "🔵", "🔺", "🔵", "❓"],
            "opciones": [
              { "emoji": "🔺", "valor": "triangulo", "texto": "Triángulo" },
              { "emoji": "🔵", "valor": "circulo", "texto": "Círculo" },
              { "emoji": "🟩", "valor": "cuadrado", "texto": "Cuadrado" }
            ],
            "correcta": "triangulo",
            "pista": "Se turnan de uno en uno."
          }
        },
        {
          "tipo": "patron_visual",
          "enunciado": "Patrón AAB: mira con cuidado, ¿qué sigue?",
          "datos": {
            "secuencia": ["🟢", "🟢", "🟡", "🟢", "🟢", "❓"],
            "opciones": [
              { "emoji": "🟢", "valor": "verde", "texto": "Verde" },
              { "emoji": "🟡", "valor": "amarillo", "texto": "Amarillo" },
              { "emoji": "🔴", "valor": "rojo", "texto": "Rojo" }
            ],
            "correcta": "amarillo",
            "pista": "Dos verdes y un amarillo, una y otra vez."
          }
        },
        {
          "tipo": "patron_visual",
          "enunciado": "Patrón ABB: el más difícil. ¿Qué sigue?",
          "datos": {
            "secuencia": ["🔵", "🔴", "🔴", "🔵", "🔴", "🔴", "❓"],
            "opciones": [
              { "emoji": "🔵", "valor": "azul", "texto": "Azul" },
              { "emoji": "🔴", "valor": "rojo", "texto": "Rojo" },
              { "emoji": "🟣", "valor": "morado", "texto": "Morado" }
            ],
            "correcta": "azul",
            "pista": "Un azul y dos rojos forman cada grupo."
          }
        }
      ]
    }
  }
}
