        },
        {
          "tipo": "patron_visual",
          "enunciado": "Patrón de 4 colores: ¿qué sigue?",
          "datos": {
            "secuencia": ["🔴", "🔵", "🟢", "🟡", "🔴", "🔵", "🟢", "❓"],
