            "opciones": [
              { "emoji": "4️⃣", "valor": "4", "texto": "4" },
              { "emoji": "5️⃣", "valor": "5", "texto": "5" },
              { "emoji": "6️⃣", "valor": "6", "texto": "6" }
            ],
            "correcta": "4",
            "pista": "3 + 2 = 5, y luego quita 1."
          }
        },
        {
          "tipo": "seleccion",
          "enunciado": "Hay 6 sillas. Llegan 6 niños y 2 adultos. ¿Alcanzan las sillas?",
