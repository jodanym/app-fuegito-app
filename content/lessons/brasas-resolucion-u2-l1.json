            "opciones": [
              { "emoji": "🚫", "valor": "faltan", "texto": "No, faltan 2 sillas" },
              { "emoji": "✅", "valor": "sobran", "texto": "Sí, sobran sillas" },
              { "emoji": "🟰", "valor": "justas", "texto": "Sí, quedan justas" }
            ],
            "correcta": "faltan",
            "pista": "Cuenta las personas: 6 + 2 = 8, y solo hay 6 sillas."
          }
        },
        {
          "tipo": "seleccion",
          "enunciado": "Compras 2 panes de $2 cada uno y pagas con $5. ¿Cuánto te devuelven?",
          "datos": {
            "opciones": [
              { "emoji": "1️⃣", "valor": "1", "texto": "$1" },
              { "emoji": "2️⃣", "valor": "2", "texto": "$2" },
              { "emoji": "3️⃣", "valor": "3", "texto": "$3" }
            ],
            "correcta": "1",
            "pista": "2 panes cuestan $4. $5 - $4 = ?"
          }
        }
      ]
    }
  }
}
